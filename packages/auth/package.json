{
  "name": "@flow/auth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./server-admin": {
      "types": "./src/server-admin.ts",
      "default": "./dist/server-admin.js"
    },
    "./env": {
      "types": "./src/env.ts",
      "default": "./dist/env.js"
    },
    "./device-trust": {
      "types": "./src/device-trust.ts",
      "default": "./dist/device-trust.js"
    },
    "./device-types": {
      "types": "./src/device-types.ts",
      "default": "./dist/device-types.js"
    },
    "./gmail-env": {
      "types": "./src/gmail-env.ts",
      "default": "./dist/gmail-env.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@flow/db": "workspace:*",
    "@flow/types": "workspace:*"
  },
  "devDependencies": {
    "@flow/config": "workspace:*",
    "@flow/eslint-config": "workspace:*",
    "@types/node": "^25.6.0",
    "jsdom": "^26.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
