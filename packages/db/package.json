{
  "name": "@flow/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./dist/client.js"
    },
    "./queries/undo/undo-helpers": {
      "types": "./src/queries/undo/undo-helpers.ts",
      "default": "./dist/queries/undo/undo-helpers.js"
    },
    "./queries/undo/conflict-detection": {
      "types": "./src/queries/undo/conflict-detection.ts",
      "default": "./dist/queries/undo/conflict-detection.js"
    },
    "./queries/undo/conflict-types": {
      "types": "./src/queries/undo/conflict-types.ts",
      "default": "./dist/queries/undo/conflict-types.js"
    },
    "./vault/inbox-tokens": {
      "types": "./src/vault/inbox-tokens.ts",
      "default": "./dist/vault/inbox-tokens.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:check": "drizzle-kit check"
  },
  "dependencies": {
    "@flow/shared": "workspace:*",
    "@flow/trust": "workspace:*",
    "@flow/types": "workspace:*",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.0",
    "drizzle-orm": "^0.44.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@flow/config": "workspace:*",
    "@flow/eslint-config": "workspace:*",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.0",
    "jsdom": "^26.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
